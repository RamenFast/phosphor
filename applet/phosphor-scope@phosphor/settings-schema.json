{
    "colorMode": {
        "type": "combobox",
        "default": "theme",
        "description": "Trace colour",
        "options": {
            "Follow panel theme": "theme",
            "Phosphor colour": "phosphor"
        }
    },
    "phosphorTheme": {
        "type": "combobox",
        "default": "P7 Green",
        "description": "Phosphor colour (when not following the theme)",
        "options": {
            "P7 Green": "P7 Green",
            "Amber": "Amber",
            "Ice Blue": "Ice Blue",
            "White": "White",
            "Vaporwave": "Vaporwave",
            "Red Phosphor": "Red Phosphor",
            "Ultraviolet": "Ultraviolet",
            "Solar Gold": "Solar Gold",
            "Cyan Tube": "Cyan Tube"
        }
    },
    "background": {
        "type": "combobox",
        "default": "transparent",
        "description": "Scope background",
        "options": {
            "Transparent (blend into panel)": "transparent",
            "AMOLED black": "amoled",
            "Themed (tint of the trace colour)": "themed"
        }
    },
    "mode": {
        "type": "combobox",
        "default": "xy",
        "description": "Scope mode",
        "options": {
            "XY · scope art": "xy",
            "Goniometer": "xy45",
            "XY · dots": "xy_dots",
            "Waveform": "waveform",
            "Spectrum": "spectrum",
            "Spectrum · radial": "spectrum_radial"
        }
    },
    "squareInPanel": {
        "type": "checkbox",
        "default": false,
        "description": "Make it a true square (match the panel height)"
    },
    "panelWidth": {
        "type": "spinbutton",
        "default": 48,
        "min": 24,
        "max": 200,
        "step": 4,
        "units": "px",
        "description": "Width in the panel (ignored when 'true square' is on)",
        "dependency": "!squareInPanel"
    },
    "fps": {
        "type": "combobox",
        "default": 30,
        "description": "Refresh rate (lower = less CPU)",
        "options": {
            "Battery saver (15 fps)": 15,
            "Balanced (30 fps)": 30,
            "Smooth (60 fps)": 60
        }
    }
}
