[Desktop Entry]
Type=Application
Name=Phosphor
GenericName=XY Oscilloscope
Comment=CRT-style oscilloscope visualizer for everything your PC plays
Exec=phosphor %f
Icon=phosphor-scope
Terminal=false
Categories=AudioVideo;Audio;
Keywords=oscilloscope;scope;XY;goniometer;visualizer;audio;music;
MimeType=audio/x-wav;audio/flac;audio/mpeg;audio/ogg;audio/opus;audio/mp4;
StartupWMClass=phosphor
